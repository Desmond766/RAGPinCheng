# Zhipu GLM — required for answer generation. Get one at https://bigmodel.cn.
ZHIPU_API_KEY=

# MinerU cloud API — required for PDF parsing during indexing (~1 min/PDF).
# Without this, scripts/build_index.py falls back to the local mineru CLI
# (~5-15 min/PDF, CPU-only). Get one at https://mineru.net.
MINERU_API_KEY=

# Override the default LLM model id used for answer generation. Leave blank to
# use src/config.py's default (currently glm-4.6). Common values: glm-4.6,
# glm-4.5-air, GLM-4.7-flashx.
LLM_MODEL=glm-4.7-flashx

# Optional: model used only for the standalone-query rewrite step. The rewrite
# is short and latency-sensitive, so picking a faster/cheaper model here keeps
# multi-turn follow-ups snappy while answer generation can still use a stronger
# model via LLM_MODEL. Defaults to LLM_MODEL when unset.
LLM_REWRITE_MODEL=glm-4.5-air

# HuggingFace endpoint. Leave unset to use the real CDN. Set to
# https://hf-mirror.com if the host can't reach huggingface.co directly
# (common on restricted networks in mainland China).
# HF_ENDPOINT=https://hf-mirror.com

# Docker build target architecture (consumed by docker-compose.yml's
# build.platforms). Defaults to linux/amd64 — leave unset on the production
# x86_64 server. On arm64 systems, set linux/arm64 so local builds run
# native instead of through QEMU emulation (~5-10x faster for the rerank
# workload).
# BUILD_PLATFORM=linux/arm64
