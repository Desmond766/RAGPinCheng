# Build context is the repo root. Keep it small — the backend image COPYs
# src/, api/, prompts/, scripts/, requirements-prod.txt, and the frontend
# source (the first build stage runs `npm run build` to produce dist/).

.git
.gitignore
.venv
venv
__pycache__
**/__pycache__
*.pyc
*.pyo
.DS_Store

# Local dev artifacts
.env
.env.example
.claude/

# Frontend: we ship the SOURCE so the node stage can build it inside the
# image. Exclude local build artifacts and node_modules to keep the context
# small and force a clean install inside the container.
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/tsconfig.tsbuildinfo

# Bind-mounted at runtime, not baked into the image
data/
docs/

# Streamlit UI is not part of the deployment
app.py

# Repo docs / scratch
README.md
README_zh.md
CLAUDE.md
TODO
*.html
eval_run.log
src/eval/runs/
src/eval/sampled_parents.json
src/eval/drafts.jsonl

# Local-dev requirements (we use requirements-prod.txt in-image)
requirements.txt

# Docker config doesn't need to ship into the image
docker/
