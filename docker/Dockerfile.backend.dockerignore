# Build context is the repo root. Keep it small — only what the backend image
# actually COPYs (src/, api/, prompts/, scripts/, requirements-prod.txt).

.git
.gitignore
.venv
venv
__pycache__
**/__pycache__
*.pyc
*.pyo
.DS_Store

# Local dev artifacts
.env
.env.example
.claude/

# Frontend lives in its own image
frontend/

# Bind-mounted at runtime, not baked into the image
data/
docs/

# Streamlit UI is not part of the deployment
app.py

# Repo docs / scratch
README.md
README_zh.md
CLAUDE.md
TODO
*.html
eval_run.log
src/eval/runs/
src/eval/sampled_parents.json
src/eval/drafts.jsonl

# Local-dev requirements (we use requirements-prod.txt in-image)
requirements.txt

# Docker config doesn't need to ship into the image
docker/
